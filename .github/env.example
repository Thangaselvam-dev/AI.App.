# ─────────────────────────────────────────────
# DMK Campaign Studio — Environment Variables
# Copy this file to .env and fill in your keys
# NEVER commit .env to GitHub
# ─────────────────────────────────────────────

# Server
PORT=5000
NODE_ENV=development

# JWT Secret (make this a long random string)
JWT_SECRET=your_super_secret_key_change_this

# OpenAI (for Tamil captions + reel scripts)
OPENAI_API_KEY=sk-...your-key-here...

# Stability AI (for DMK poster generation)
STABILITY_API_KEY=sk-...your-key-here...

# PostgreSQL Database
DB_HOST=localhost
DB_PORT=5432
DB_NAME=dmk_campaign
DB_USER=postgres
DB_PASSWORD=your_db_password

# AWS S3 (for storing posters/images)
AWS_ACCESS_KEY=your_access_key
AWS_SECRET_KEY=your_secret_key
AWS_BUCKET_NAME=dmk-campaign-assets
AWS_REGION=ap-south-1

# Meta / Instagram Graph API
META_APP_ID=your_meta_app_id
META_APP_SECRET=your_meta_app_secret
INSTAGRAM_USER_ID=your_ig_user_id
META_ACCESS_TOKEN=your_long_lived_access_token
